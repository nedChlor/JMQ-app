# ============================================================
# JMQ Service Manual — .gitignore
# ============================================================

# --- Raw source data (large binaries) ---
src/data_raw/documents/
src/data_raw/dtc_source.xlsx

# --- Generated developer artifacts ---
src/output/

# --- Generated app assets ---
app_assets/db/
app_assets/pdf/

# --- Flutter build ---
jmq_app/build/
jmq_app/.dart_tool/
jmq_app/.flutter-plugins*
jmq_app/.packages

# --- Flutter large assets (regenerate from Python scripts) ---
jmq_app/assets/pdf/

# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/
*.swp
